# ═══════════════════════════════════════════
# GitHub Store Bot - Environment Variables
# ═══════════════════════════════════════════

# ─── الإعدادات الإجبارية ─────────────────

# توكن بوت تيليجرام (من @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# مفتاح تشفير لتأمين توكنات GitHub (استخدم أي نص عشوائي طويل)
# مثال: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=your_random_encryption_key_here

# ─── إعدادات Webhook (لنشر Railway) ──────

# وضع التشغيل: polling (محلي) أو webhook (Railway)
BOT_MODE=webhook

# رابط الـ Webhook الكامل (يُحدد بعد النشر على Railway)
# مثال: https://your-app.up.railway.app/webhook
WEBHOOK_URL=

# منفذ الخادم (Railway يُحدده تلقائياً عبر PORT)
WEBHOOK_PORT=8080

# توكن سري للتحقق من هوية طلبات الـ Webhook (اختياري)
WEBHOOK_SECRET=

# ─── إعدادات اختيارية ──────────────────

# مسار قاعدة البيانات (في Railway استخدم /data/)
# DB_PATH=/data/github_store_bot.db

# مستوى التسجيل: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# مهلة طلبات GitHub API (بالثواني)
GITHUB_API_TIMEOUT=15

# الحد الأقصى لحجم الملف للرفع المباشر (بالميجابايت)
MAX_FILE_SIZE_MB=49

# الحد الأقصى لطول وصف الإصدار
MAX_DESCRIPTION_LENGTH=300